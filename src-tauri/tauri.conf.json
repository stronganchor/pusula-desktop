{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pusula",
  "version": "0.1.0",
  "identifier": "com.stronganchor.pusula",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pusula",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "publisher": "Strong Anchor Technology",
    "copyright": "Copyright © 2026 Strong Anchor Technology",
    "shortDescription": "Offline-first Pusula business records",
    "longDescription": "Single-machine Windows application for offline customer, sale, installment, payment, report, receipt, and encrypted backup workflows.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["Turkish", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFNEFCMzZCQTQ0MzFBMApSV1NnTVVTNk5xdmtCVVdQdExrbGgwc3AzRTBDUEZHTVQ3QnlKOVZLMUVBQU9Xa3A0RitxZnBrOQo=",
      "endpoints": [
        "https://github.com/stronganchor/pusula-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

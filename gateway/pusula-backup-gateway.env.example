# Copy to /etc/pusula-backup-gateway.env as root:root mode 0600.
# Replace every REPLACE_* value. Never commit the completed file.

PUSULA_GATEWAY_BIND=127.0.0.1:12741
PUSULA_GATEWAY_DATABASE=/var/lib/pusula-backup-gateway/gateway.sqlite3
PUSULA_GATEWAY_OBJECT_ROOT=/var/lib/pusula-backup-gateway/objects
PUSULA_GATEWAY_TOKEN_PEPPER=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES

PUSULA_GATEWAY_MAX_BACKUP_BYTES=268435456
PUSULA_GATEWAY_MIN_FREE_BYTES=1073741824
PUSULA_GATEWAY_RESERVATION_TTL_SECONDS=900
PUSULA_GATEWAY_UPLOAD_BURST=5
PUSULA_GATEWAY_UPLOAD_REFILL_SECONDS=60
PUSULA_GATEWAY_MAX_PENDING_PER_DEVICE=8
# Must be at least 2 * MAX_BACKUP_BYTES because the conservative persisted
# ledger charges one reservation and its authenticated relay admission.
PUSULA_GATEWAY_DEVICE_24H_BYTE_QUOTA=1073741824
PUSULA_GATEWAY_PENDING_MAX_AGE_SECONDS=2592000
PUSULA_GATEWAY_PENDING_CLEANUP_LIMIT=100
PUSULA_GATEWAY_AUTHORIZATION_CLEANUP_LIMIT=500
PUSULA_GATEWAY_DAILY_MIN_INTERVAL_SECONDS=72000
PUSULA_GATEWAY_MONTHLY_MIN_INTERVAL_SECONDS=2160000

# Local encrypted-object retention. Cleanup is bounded, resumable, and always
# preserves the newest completed object for each device/retention class.
PUSULA_GATEWAY_RETENTION_ROLLING_DAYS=14
PUSULA_GATEWAY_RETENTION_DAILY_DAYS=60
PUSULA_GATEWAY_RETENTION_MONTHLY_DAYS=400
PUSULA_GATEWAY_RETENTION_CLEANUP_LIMIT=100

# Shared-host load shedding. Health checks bypass these request gates.
PUSULA_GATEWAY_MAX_REQUEST_CONCURRENCY=8
PUSULA_GATEWAY_MAX_DB_CONCURRENCY=4
PUSULA_GATEWAY_GLOBAL_REQUEST_BURST=60
PUSULA_GATEWAY_GLOBAL_REQUEST_REFILL_SECONDS=1

RUST_LOG=pusula_backup_gateway=info

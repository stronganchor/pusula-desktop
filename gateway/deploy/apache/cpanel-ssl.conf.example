# Install as:
# /etc/apache2/conf.d/userdata/ssl/2_4/__CPANEL_USER__/__VHOST__/pusula-backup-gateway.conf
#
# __VHOST__ is the actual cPanel Apache SSL vhost name for
# pusula-backup.stronganchortech.com. Keep TCP 12741 closed in CSF; only Apache
# should reach this loopback listener.

ProxyRequests Off
ProxyPreserveHost On
ProxyAddHeaders On
RequestHeader set X-Forwarded-Proto "https"

# Per-Apache-child backend pools fail within one second instead of accumulating
# an unbounded proxy wait queue. The gateway independently enforces process-wide
# request, DB, aggregate-rate, and single-relay limits. Completion streams the
# entire encrypted B2 object through SHA-256, so it needs the bounded long
# response window without receiving the relay route's large request-body limit.
ProxyPass        "/v1/backups/complete" "http://127.0.0.1:12741/v1/backups/complete" connectiontimeout=5 timeout=900 retry=0 max=2 acquire=1000
ProxyPassReverse "/v1/backups/complete" "http://127.0.0.1:12741/v1/backups/complete"
ProxyPass        "/v1/backups/relay/" "http://127.0.0.1:12741/v1/backups/relay/" connectiontimeout=5 timeout=900 retry=0 max=1 acquire=1000
ProxyPassReverse "/v1/backups/relay/" "http://127.0.0.1:12741/v1/backups/relay/"
ProxyPass        "/" "http://127.0.0.1:12741/" connectiontimeout=5 timeout=25 retry=0 max=16 acquire=1000
ProxyPassReverse "/" "http://127.0.0.1:12741/"

<Location "/">
    Require all granted
    LimitRequestBody 16384
</Location>

# Keep this more-specific override after the general Location section so the
# relay does not inherit the 16 KiB JSON-body limit.
<Location "/v1/backups/relay/">
    Require all granted
    LimitRequestBody 268435456
</Location>
